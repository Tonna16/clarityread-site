{
  "manifest_version": 3,
  "name": "ClarityRead — Reading Mode + Dyslexia Support",
  "version": "0.1",
  "description": "Toggle dyslexia-friendly font, reflow text, contrast, and read-aloud on any page.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus",
    "commands"
  ],
  "host_permissions": [],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "fonts/*",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "read-aloud": {
      "suggested_key": { "default": "Alt+R" },
      "description": "Start reading aloud the main content"
    },
    "stop-reading": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Stop reading aloud"
    }
  }
}
